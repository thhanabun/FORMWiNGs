{
  "model_type": "rulebase",
  "feature_columns": [
    "cadence_spm",
    "vertical_oscillation_cm",
    "gct_flight_balance_ms",
    "impact_loading_rate_bw_s",
    "trunk_forward_lean_deg",
    "left_right_asymmetry_pct",
    "heel_strike_likelihood"
  ],
  "class_names": [
    "Good",
    "Bad Form"
  ],
  "primary_output": "probabilities [Good, Bad Form]",
  "normalizer_required": false,
  "rules": {
    "cadence_spm": {
      "low": 160,
      "high": 200
    },
    "vertical_oscillation_cm": {
      "low": 4,
      "high": 10
    },
    "gct_ms": {
      "high": 300
    },
    "peak_vgrf_bw_estimate": {
      "warning": 2.0,
      "danger": 2.5
    },
    "trunk_forward_lean_deg": {
      "low": 3,
      "high": 15
    },
    "left_right_asymmetry_pct": {
      "high": 10
    },
    "footstrike_time_to_peak_ms": {
      "heel_strike_below": 15
    },
    "arm_swing_proxy": {
      "low": 0.25,
      "note": "Optional diagnostic; current waist IMU extractor does not add this field to the default payload."
    }
  }
}
